diff --git a/apps/api/src/config/env.validation.ts b/apps/api/src/config/env.validation.ts
new file mode 100644
index 0000000..741cb6f
--- /dev/null
+++ b/apps/api/src/config/env.validation.ts
@@ -0,0 +1,60 @@
+import { plainToInstance } from 'class-transformer';
+import {
+  IsEnum,
+  IsInt,
+  IsNotEmpty,
+  IsString,
+  Max,
+  Min,
+  validateSync,
+} from 'class-validator';
+
+enum Environment {
+  Development = 'development',
+  Production = 'production',
+  Test = 'test',
+}
+
+class EnvironmentVariables {
+  @IsEnum(Environment)
+  NODE_ENV: Environment;
+
+  @IsInt()
+  @Min(1)
+  @Max(65535)
+  PORT: number;
+
+  @IsString()
+  @IsNotEmpty()
+  DATABASE_URL: string;
+
+  @IsString()
+  @IsNotEmpty()
+  APP_NAME: string;
+
+  @IsString()
+  @IsNotEmpty()
+  APP_VERSION: string;
+}
+
+/**
+ * FunĂ§ĂŁo de validaĂ§ĂŁo passada para `ConfigModule.forRoot({ validate })`.
+ * Se alguma variĂˇvel obrigatĂłria estiver ausente ou invĂˇlida, o boot da
+ * aplicaĂ§ĂŁo falha imediatamente com uma mensagem descritiva, em vez de
+ * falhar silenciosamente mais tarde em runtime (ex: connection string vazia).
+ */
+export function validate(config: Record<string, unknown>) {
+  const validatedConfig = plainToInstance(EnvironmentVariables, config, {
+    enableImplicitConversion: true,
+  });
+
+  const errors = validateSync(validatedConfig, {
+    skipMissingProperties: false,
+  });
+
+  if (errors.length > 0) {
+    throw new Error(`ConfiguraĂ§ĂŁo de ambiente invĂˇlida:\n${errors.toString()}`);
+  }
+
+  return validatedConfig;
+}
