+import { Global, Module } from '@nestjs/common';
+import { ConfigModule as NestConfigModule } from '@nestjs/config';
+
+import configuration from './configuration';
+import { AppConfigService } from './config.service';
+import { validate } from './env.validation';
+
+/**
+ * MĂłdulo global de configuraĂ§ĂŁo da aplicaĂ§ĂŁo.
+ * Marcado como @Global() para seguir o mesmo padrĂŁo jĂˇ usado pelo
+ * PrismaModule, jĂˇ que AppConfigService Ă© uma dependĂŞncia transversal
+ * consumida por mĂşltiplos mĂłdulos (Prisma, Health, etc.).
+ */
+@Global()
+@Module({
+  imports: [
+    NestConfigModule.forRoot({
+      isGlobal: true,
+      load: [configuration],
+      validate,
+    }),
+  ],
+  providers: [AppConfigService],
+  exports: [AppConfigService],
+})
+export class ConfigModule {}
