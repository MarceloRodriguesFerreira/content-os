+export interface AppConfig {
+  nodeEnv: string;
+  port: number;
+  app: {
+    name: string;
+    version: string;
+  };
+  database: {
+    url: string;
+  };
+}
+
+/**
+ * Ăšnica funĂ§ĂŁo da aplicaĂ§ĂŁo autorizada a ler `process.env` diretamente.
+ * Ă‰ registrada via `ConfigModule.forRoot({ load: [configuration] })` e
+ * roda depois que `env.validation.ts` jĂˇ validou as variĂˇveis obrigatĂłrias.
+ */
+export default (): AppConfig => ({
+  nodeEnv: process.env.NODE_ENV ?? 'development',
+  port: parseInt(process.env.PORT ?? '3001', 10),
+  app: {
+    name: process.env.APP_NAME ?? 'Content OS',
